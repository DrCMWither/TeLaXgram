{
  "name": "telaxgram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TeLaXgram: Telegram inline rich text / table / LaTeX renderer on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run check && npm run test",
    "set-webhook": "bash scripts/set-webhook.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260612.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  }
}
