{
  "name": "telaxgram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TeLaXgram: Telegram inline rich text / table / LaTeX renderer on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run check && npm run test",
    "set-webhook": "bash scripts/set-webhook.sh"
  },
  "devDependencies": {
  "@cloudflare/workers-types": "latest",
  "typescript": "latest",
  "wrangler": "latest"
}

}
